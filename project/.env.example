# LUMINA Environment Configuration
# Copy this to .env and fill in your credentials

# GitHub Personal Access Token
# Required scopes: repo, fork
# --- API Keys ---
GITHUB_TOKEN= # Optional: for fallback demo mode
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=lumina-security

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Security ---
SESSION_SECRET= # Random long string for JWT signing
